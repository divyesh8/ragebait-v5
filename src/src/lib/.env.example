# === Required for auth to work ===

# Neon / Vercel Postgres connection string
# Get this from: Vercel dashboard -> Storage -> Create Database -> Postgres (Neon)
# It auto-injects DATABASE_URL into your project's env vars.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string

# === Not used yet, reserved for future modules ===

# Redis
REDIS_URL=

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI / OpenAI
OPENAI_API_KEY=

# Email (OTP verification)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
