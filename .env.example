# === Required for auth to work ===

# Neon / Vercel Postgres connection string
# Get this from: Vercel dashboard -> Storage -> Create Database -> Postgres (Neon)
# It auto-injects DATABASE_URL (or POSTGRES_URL) into your project's env vars.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string

# Founder-only creator control panel identity.
# The frontend never receives this value; the server returns only isCreator=true/false.
FOUNDER_EMAIL=kolli.divyesh08@gmail.com

# === Required for the AI Judge to work ===

# OpenAI API key — used to score battles and pick winners.
# Get one from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === Not used yet, reserved for future modules ===

# Redis
REDIS_URL=

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (OTP verification)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
